{
  "extraKnownMarketplaces": {
    "nx-claude-plugins": {
      "source": {
        "source": "github",
        "repo": "nrwl/nx-ai-agents-config"
      }
    },
    "opengsd-local": {
      "source": {
        "source": "directory",
        "path": ".gsd-opengsd/1.6.1/package"
      }
    }
  },
  "enabledPlugins": {
    "nx@nx-claude-plugins": true,
    "gsd-core@opengsd-local": true
  },
  "sandbox": {
    "network": {
      "allowedDomains": [
        "www.google-analytics.com"
      ]
    }
  },
  "env": {
    "RUNTIME_DIR": ".gsd-opengsd/1.6.1/package"
  },
  "skillOverrides": {
    "gsd-add-tests": "off",
    "gsd-ai-integration-phase": "off",
    "gsd-audit-fix": "off",
    "gsd-audit-milestone": "off",
    "gsd-audit-uat": "off",
    "gsd-autonomous": "off",
    "gsd-capture": "off",
    "gsd-cleanup": "off",
    "gsd-code-review": "off",
    "gsd-complete-milestone": "off",
    "gsd-config": "off",
    "gsd-debug": "off",
    "gsd-discuss-phase": "off",
    "gsd-docs-update": "off",
    "gsd-eval-review": "off",
    "gsd-execute-phase": "off",
    "gsd-explore": "off",
    "gsd-extract-learnings": "off",
    "gsd-fast": "off",
    "gsd-forensics": "off",
    "gsd-graphify": "off",
    "gsd-health": "off",
    "gsd-help": "off",
    "gsd-import": "off",
    "gsd-inbox": "off",
    "gsd-ingest-docs": "off",
    "gsd-manager": "off",
    "gsd-map-codebase": "off",
    "gsd-milestone-summary": "off",
    "gsd-mvp-phase": "off",
    "gsd-new-milestone": "off",
    "gsd-new-project": "off",
    "gsd-ns-context": "off",
    "gsd-ns-ideate": "off",
    "gsd-ns-manage": "off",
    "gsd-ns-project": "off",
    "gsd-ns-review": "off",
    "gsd-ns-workflow": "off",
    "gsd-pause-work": "off",
    "gsd-phase": "off",
    "gsd-plan-phase": "off",
    "gsd-plan-review-convergence": "off",
    "gsd-pr-branch": "off",
    "gsd-profile-user": "off",
    "gsd-progress": "off",
    "gsd-quick": "off",
    "gsd-resume-work": "off",
    "gsd-review": "off",
    "gsd-review-backlog": "off",
    "gsd-secure-phase": "off",
    "gsd-settings": "off",
    "gsd-ship": "off",
    "gsd-sketch": "off",
    "gsd-spec-phase": "off",
    "gsd-spike": "off",
    "gsd-stats": "off",
    "gsd-surface": "off",
    "gsd-thread": "off",
    "gsd-ui-phase": "off",
    "gsd-ui-review": "off",
    "gsd-ultraplan-phase": "off",
    "gsd-undo": "off",
    "gsd-update": "off",
    "gsd-validate-phase": "off",
    "gsd-verify-work": "off",
    "gsd-workspace": "off",
    "gsd-workstreams": "off"
  },
  "permissions": {
    "deny": [
      "Agent(gsd-advisor-researcher)",
      "Agent(gsd-ai-researcher)",
      "Agent(gsd-assumptions-analyzer)",
      "Agent(gsd-code-fixer)",
      "Agent(gsd-code-reviewer)",
      "Agent(gsd-codebase-mapper)",
      "Agent(gsd-debug-session-manager)",
      "Agent(gsd-debugger)",
      "Agent(gsd-doc-classifier)",
      "Agent(gsd-doc-synthesizer)",
      "Agent(gsd-doc-verifier)",
      "Agent(gsd-doc-writer)",
      "Agent(gsd-domain-researcher)",
      "Agent(gsd-eval-auditor)",
      "Agent(gsd-eval-planner)",
      "Agent(gsd-executor)",
      "Agent(gsd-framework-selector)",
      "Agent(gsd-integration-checker)",
      "Agent(gsd-intel-updater)",
      "Agent(gsd-nyquist-auditor)",
      "Agent(gsd-pattern-mapper)",
      "Agent(gsd-phase-researcher)",
      "Agent(gsd-plan-checker)",
      "Agent(gsd-planner)",
      "Agent(gsd-project-researcher)",
      "Agent(gsd-research-synthesizer)",
      "Agent(gsd-roadmapper)",
      "Agent(gsd-security-auditor)",
      "Agent(gsd-ui-auditor)",
      "Agent(gsd-ui-checker)",
      "Agent(gsd-ui-researcher)",
      "Agent(gsd-user-profiler)",
      "Agent(gsd-verifier)"
    ]
  }
}
