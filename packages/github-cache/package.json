  "repository": {
    "type": "git",
    "url": "git+https://github.com/op-nx/github-cache.git"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@op-nx/source": "./src/index.ts",
