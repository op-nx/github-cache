  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@actions/cache": "6.2.0",
    "@actions/core": "3.0.1",
    "@octokit/plugin-retry": "8.1.0",
    "@octokit/plugin-throttling": "11.0.3",
    "@octokit/rest": "22.0.1"
  }
}
