{
  "name": "@op-nx/github-cache",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@op-nx/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!**/*.tsbuildinfo"
  ],
  "bin": {
    "op-nx-github-cache-serve": "./dist/bin/serve.js",
    "op-nx-github-cache-publish-mirror": "./dist/bin/publish-mirror.js"
  },
  "scripts": {
    "test:act": "cd ../.. && act push --cache-server-path=packages/op-nx-github-cache/.act-cache --artifact-server-path=packages/op-nx-github-cache/.act-artifacts -W packages/op-nx-github-cache/__fixtures__/act-workflow.yml",
    "test:act:untrusted": "cd ../.. && act pull_request_target --cache-server-path=packages/op-nx-github-cache/.act-cache --artifact-server-path=packages/op-nx-github-cache/.act-artifacts -W packages/op-nx-github-cache/__fixtures__/act-workflow.yml -e packages/op-nx-github-cache/__fixtures__/pull_request_target-event.json"
  },
  "nx": {
    "release": {
      "version": {
        "currentVersionResolver": "git-tag",
        "fallbackCurrentVersionResolver": "disk"
      }
    }
  },
  "dependencies": {
    "tslib": "^2.3.0",
    "@actions/cache": "^6.2.0",
    "@octokit/rest": "^22.0.1"
  }
}
